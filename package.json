{
  "name": "agentic-press",
  "version": "0.0.1",
  "description": "MCP proxy layer for secure AI agent execution in Docker Sandbox (sbx)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentic-press-dispatch": "dist/dispatch/index.js",
    "apd": "dist/dispatch/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dispatch": "tsx src/dispatch/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "sweep-improvements": "tsx scripts/sweep-improvements.mjs",
    "sweep-skill-metrics": "tsx scripts/sweep-improvements.mjs --skip-audit",
    "address-improvement": "node scripts/address-improvement.mjs"
  },
  "keywords": [
    "mcp",
    "sandbox",
    "ai-agent",
    "security",
    "docker"
  ],
  "author": "Jeff Zickgraf",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "pino": "^10.3.1"
  },
  "optionalDependencies": {
    "@langfuse/client": "^5.3.0",
    "@langfuse/core": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "prom-client": "^15.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
