# MCP Proxy Configuration
MCP_PROXY_PORT=18923
ALLOWED_TOOLS=filesystem.*,Read,Write,Grep,Glob

# LOG_LEVEL controls structured logger verbosity (pino JSON output).
# Valid: debug | info | warn | error. Unknown values fall back to "info".
# All diagnostic output is structured JSON (pino) — pipe through `pino-pretty`
# for human-readable output during development, or ingest directly into
# log collectors (Loki, ELK, CloudWatch) in production.
# - debug: log every non-JSON line emitted by child MCP servers (verbose)
# - info | warn | error: emit a one-shot warning the first time a server emits non-JSON
#   output; silent for subsequent lines from that same server.
LOG_LEVEL=info

# AUDIT_LOG_FILE — optional path to a dedicated file for the NDJSON audit
# stream. When set, audit entries are written here with synchronous writes
# (no stream buffering, no pino interleave). Recommended for production and
# for any workflow that captures audit data for analysis (e.g., the
# sweep-improvements script). When unset, audit entries go to stdout
# alongside pino diagnostics.
# AUDIT_LOG_FILE=/var/log/agentic-press/audit.ndjson

# MCP Server Definitions (JSON array)
# MCP_SERVERS=[{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/workspace"]}]
#
# HTTP transport (Phase 2 — for remote MCP servers behind a load balancer):
# # https:// is required for non-localhost (no plain HTTP to remote servers).
# # Localhost (http://localhost, 127.0.0.1, ::1) is permitted for local dev.
# MCP_SERVERS=[{"name":"remote","transport":"http","url":"https://mcp.example.com/mcp","bearerToken":"YOUR_TOKEN_HERE"}]

# Tool-name -> server routing (JSON object). REQUIRED if MCP_SERVERS is set.
# Map tool-name globs to server names declared in MCP_SERVERS.
# Boot fails fast unless MCP_SERVERS and SERVER_ROUTES are both set or both unset.
# SERVER_ROUTES={"filesystem__*":"filesystem"}

# Langfuse (optional — proxy works without these)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Maximum size in bytes for a single upstream MCP response line. Enforced at the
# stdio-bridge read layer to prevent a hostile or misbehaving MCP server from
# OOMing the proxy with an unbounded response. Default 10 MiB. Set to 0 to
# disable. Operators with large-file workflows may need to raise this.
# MAX_RESPONSE_BYTES=10485760

# Prometheus Metrics (optional)
# Prometheus Metrics (optional — opt-in by uncommenting)
# When set, exposes /metrics on the given port for Grafana/Prometheus scraping.
# METRICS_PORT=9090
# METRICS_BIND defaults to 127.0.0.1 — process metrics (heap, gc, cpu) are sensitive.
# Set to 0.0.0.0 only if a remote scraper (e.g. Grafana Alloy) needs access.
# METRICS_BIND=127.0.0.1

# Mission Control (optional — proxy works without these)
# MISSION_CONTROL_URL=http://localhost:3000
# MISSION_CONTROL_API_KEY=
